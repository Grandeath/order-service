LOG_LEVEL=INFO

API_PORT=8080
API_READ_TIMEOUT=15s
API_WRITE_TIMEOUT=15s

TECHNICAL_PORT=9090
TECHNICAL_READ_TIMEOUT=15s
TECHNICAL_WRITE_TIMEOUT=15s

DB_DSN=postgres://order:order@localhost:5432/orders?sslmode=disable
DB_MAX_CONNS=10
DB_CONNECT_TIMEOUT=5s

KAFKA_ENABLED=false
KAFKA_URL=localhost:9092
KAFKA_TOPIC=order.events
KAFKA_COMPRESSION=true
KAFKA_METRICS_NAMESPACE=order_events
